{
  "name": "lince_new",
  "version": "1.0.0",
  "description": "A library of Agent Skills designed to work with the Stitch MCP server. Each skill follows the Agent Skills open standard, for compatibility with coding agents such as Antigravity, Gemini CLI, Claude Code, Cursor.",
  "main": "index.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/input.css -o ./assets/style.css && npx clean-css-cli -o ./assets/style.min.css ./assets/style.css",
    "build:js": "npx terser ./assets/app.js -o ./assets/app.min.js",
    "build": "npm run build:css && npm run build:js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Victor002823/Mudanzas-el-Lince.git"
  },
